# ============================================================
# AgendaPro — Frontend Environment Variables (Vite)
# Copie este arquivo para .env e preencha os valores reais.
# ============================================================

# ── API do Backend ──────────────────────────────────────────
# URL onde o seu servidor Node.js está rodando
VITE_API_URL=http://localhost:3001/api

# ── Supabase (Frontend) ─────────────────────────────────────
# Pegue em: Project Settings > API
VITE_SUPABASE_URL=https://sua-url.supabase.co
# Use a 'anon public' key para o frontend (respeita RLS)
VITE_SUPABASE_ANON_KEY=sua-anon-public-key

# ── Stripe (Frontend) ───────────────────────────────────────
# Pegue em: Developers > API keys
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# IDs dos Preços (Devem ser os mesmos do backend)
VITE_STRIPE_PRICE_BASIC=price_...
VITE_STRIPE_PRICE_PROFESSIONAL=price_...
VITE_STRIPE_PRICE_ENTERPRISE=price_...
