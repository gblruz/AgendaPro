# ============================================================
# AgendaPro — Backend Environment Variables
# Copie este arquivo para .env e preencha os valores reais.
# ============================================================

# ── Configurações do Servidor ────────────────────────────────
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# ── Autenticação (JWT) ───────────────────────────────────────
# Gere uma string aleatória e longa (ex: openssl rand -base64 32)
JWT_SECRET=sua_chave_secreta_aqui
JWT_EXPIRES_IN=7d

# ── Supabase (Infraestrutura) ────────────────────────────────
# Pegue em: Project Settings > API
SUPABASE_URL=https://sua-url.supabase.co
# Use a 'service_role' key para o backend (acesso total)
SUPABASE_KEY=sua-service-role-key

# ── Stripe (Pagamentos) ──────────────────────────────────────
# Pegue em: Developers > API keys
STRIPE_SECRET_KEY=sk_test_...
# Pegue em: Developers > Webhooks (após criar o endpoint)
STRIPE_WEBHOOK_SECRET=whsec_...

# IDs dos Preços (Crie no Stripe Dashboard > Products)
STRIPE_PRICE_BASIC=price_...
STRIPE_PRICE_PROFESSIONAL=price_...
STRIPE_PRICE_ENTERPRISE=price_...
